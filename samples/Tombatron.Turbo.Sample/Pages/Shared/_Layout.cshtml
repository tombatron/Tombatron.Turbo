<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Tombatron.Turbo Sample</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <turbo-scripts />
</head>
<body>
    <header>
        <div class="container">
            <a href="/" class="logo">Tombatron.<span>Turbo</span></a>
            <nav>
                <a href="/">Home</a>
                <a href="/Cart">Cart</a>
                <a href="/Streams">Streams</a>
                <a href="/Validation">Validation</a>
                <a href="/Stimulus">Stimulus</a>
                <span class="connection-status disconnected"
                      data-controller="connection-status">Offline</span>
            </nav>
        </div>
    </header>

    <main>
        <div class="container">
            @RenderBody()
        </div>
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
